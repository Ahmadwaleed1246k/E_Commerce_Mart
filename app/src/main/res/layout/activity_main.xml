<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <!-- Container for Fragments -->
        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/custom_bottom_nav"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Seller Placeholder (Deprecated, moving to fragments) -->
        <ScrollView
            android:id="@+id/seller_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" />
        </ScrollView>

        <!-- Custom Bottom Navigation (Buyer Only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/custom_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:visibility="gone"
            app:cardCornerRadius="0dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/white"
            app:strokeWidth="0dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:weightSum="6">

                <LinearLayout
                    android:id="@+id/btn_nav_home"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_home"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_home"
                        app:tint="@color/accent_color" />
                    <TextView
                        android:id="@+id/tv_nav_home"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Home"
                        android:textSize="10sp"
                        android:textColor="@color/accent_color" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nav_search"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_search"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/text_sub" />
                    <TextView
                        android:id="@+id/tv_nav_search"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nav_favourites"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_favourites"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_favorite"
                        app:tint="@color/text_sub" />
                    <TextView
                        android:id="@+id/tv_nav_favourites"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fav"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nav_orders"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_orders"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_history"
                        app:tint="@color/text_sub" />
                    <TextView
                        android:id="@+id/tv_nav_orders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Orders"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nav_cart"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_cart"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_shopping_cart"
                        app:tint="@color/text_sub" />
                    <TextView
                        android:id="@+id/tv_nav_cart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cart"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_nav_profile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/iv_nav_profile"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/text_sub" />
                    <TextView
                        android:id="@+id/tv_nav_profile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Profile"
                        android:textSize="10sp"
                        android:textColor="@color/text_sub" />
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view_seller"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/white"
        android:visibility="gone"
        app:headerLayout="@layout/nav_header_seller"
        app:menu="@menu/drawer_menu_seller"
        app:itemBackground="@drawable/drawer_item_bg"
        app:itemIconTint="@color/drawer_item_text_color"
        app:itemTextColor="@color/drawer_item_text_color"
        app:itemShapeAppearanceOverlay="@null">

        <!-- Custom Footer for Theme Switching -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:padding="24dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_help"
                    app:tint="@color/text_sub" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Colour Scheme"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/field_bg_rounded"
                android:orientation="horizontal"
                android:padding="4dp">

                <TextView
                    android:id="@+id/btn_theme_light"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/tab_selected_bg"
                    android:gravity="center"
                    android:text="Light"
                    android:drawableStart="@android:drawable/ic_menu_day"
                    android:paddingStart="12dp"
                    android:textColor="@color/black"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_theme_dark"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="Dark"
                    android:drawableStart="@android:drawable/ic_menu_recent_history"
                    android:paddingStart="12dp"
                    android:textColor="@color/text_sub" />

            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>