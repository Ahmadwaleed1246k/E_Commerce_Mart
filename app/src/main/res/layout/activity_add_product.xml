<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:text="Product"
                android:textColor="@color/text_main"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:text="Product Name"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_product_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg_rounded"
                android:hint="Sony LED"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Product Type"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_product_type"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg_rounded"
                android:hint="Television"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Product Price"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_product_price"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg_rounded"
                android:hint="$127.99"
                android:inputType="numberDecimal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Product Description"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_product_description"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg_rounded"
                android:gravity="top"
                android:hint="This LED....."
                android:padding="16dp"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Image URL (Optional)"
                android:textColor="@color/text_main"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_product_image_url"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/field_bg_rounded"
                android:hint="https://example.com/image.jpg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="@color/text_main"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_product"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="48dp"
                android:layout_marginBottom="32dp"
                android:text="Add Product"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/btn_bg"
                app:cornerRadius="12dp" />

            <ProgressBar
                android:id="@+id/add_product_progress"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/primary_color" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
